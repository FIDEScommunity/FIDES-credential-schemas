{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/FIDEScommunity/FIDES-credential-schemas/refs/heads/main/vct-schemas/proof-of-mail/1/FIDES.proof-of-mail.schema.json",
  "title": "Proof of Mail",
  "description": "This schema represents the claim set of an SD-JWT VC for a verified email address attestation as a single, flat JSON object.",
  "type": "object",
  "required": ["vct", "email", "email_verified_at", "email_verification_method"],
  "properties": {
    "vct": {
      "type": "string",
      "const": "urn:org:fides:proof-of-mail:1"
    },
    "email": {
      "type": "string",
      "format": "idn-email"
    },
    "email_verified_at": {
      "type": "string",
      "format": "date-time"
    },
    "email_verification_method": {
      "type": "string",
      "enum": [
        "email_magic_link",
        "email_otp",
        "email_challenge"
      ]
    },
    "email_verification_provider": {
      "type": "string"
    },
    "email_verification_proof_ref": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
